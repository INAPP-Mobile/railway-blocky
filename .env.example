# ── Optional ═══════════════════════════════════════════════════════════════
# Blocky ships with a sensible default config.  You only need to set one of
# the options below when you want to deviate from the defaults.

# ── Custom full config (advanced) ──────────────────────────────────────────
# Base64-encode your entire Blocky config.yml and set it here.
# This OVERRIDES the built-in default config completely.
# Generate:  cat my-config.yml | base64 -w0
# BLOCKY_CONFIG=

# ── DNS upstream resolvers (space-separated) ──────────────────────────────
# Comma-separated list of upstream DNS resolvers.
# Supported formats:  IP, tcp-tls:host:port, https://host/path, quic:host
# Default: Cloudflare DoH + Quad9 DoT
# UPSTREAM_DNS=https://cloudflare-dns.com/dns-query,tcp-tls:dns.quad9.net:853

# ── Denylist URLs (comma-separated) ────────────────────────────────────────
# URLs to blocklist files.  Each URL should be in hosts file format.
# Default: StevenBlack/hosts unified hosts file
# BLOCK_LISTS=https://raw.githubusercontent.com/StevenBlack/hosts/master/hosts

# ── Port configuration ─────────────────────────────────────────────────────
# Railway automatically sets PORT for health checks.
# Blocky serves its REST API and Prometheus metrics on this port.
# Default: 4000
# PORT=4000

# ── Log level ──────────────────────────────────────────────────────────────
# One of: trace, debug, info, warn, error
# Default: info
# LOG_LEVEL=info
